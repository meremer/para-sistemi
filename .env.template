# .env.template
# Configuration for the AI Viral Shorts Generator

# --- Model Paths ---
# Absolute or relative paths to the model files.
# Make sure to download these models and place them in the /models directory or specify the correct path.

# Text-to-Speech (TTS) Model (e.g., Piper or Coqui)
TTS_MODEL_PATH=models/tts/en_US-ljspeech-high.onnx

# Video Generation Model (e.g., Stable Diffusion XL Turbo or AnimateDiff)
VIDEO_MODEL_PATH=models/video/sd_xl_turbo_1.0.safensors

# Captioning Model (e.g., Whisper.cpp)
CAPTION_MODEL_PATH=models/whisper/ggml-base.en.bin

# --- VRAM Optimization Settings ---
# Settings to control VRAM usage to fit within an 8GB constraint.

# Enable VRAM optimizations (True/False)
ENABLE_VRAM_OPTIMIZATIONS=True

# Example of a model-specific setting
STABLE_DIFFUSION_LOW_VRAM_MODE=True


# --- Ollama LLM Settings ---
# Configuration for the local Language Model.

# The model name to use with Ollama (e.g., mistral, llama2)
OLLAMA_MODEL=mistral
