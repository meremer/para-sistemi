# Kütüphane Yönetim Sistemi - Environment Konfigürasyonu
# Bu dosyayı .env olarak kaydedin

# Server Port
PORT=3000

# JWT Secret Key (Production'da değiştirin!)
JWT_SECRET=your-secret-key-change-this-in-production

# Node Environment
NODE_ENV=development

# CORS Settings (Production'da güncelleyin)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (Gelecek PostgreSQL implementasyonu için)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=library_db
# DB_USER=postgres
# DB_PASSWORD=password

# Email Settings (Gelecek notification sistemi için)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=your-session-secret-change-this

# Rate Limiting (İçinde require etmek için)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
