# Kütüphane Yönetim Sistemi - Environment Konfigürasyonu
# Bu dosyayı .env olarak kaydedin

# Server Port
PORT=3000

# JWT Secret Key (REQUIRED - Production'da mutlaka değiştirin!)
JWT_SECRET=your-secret-key-change-this-in-production

# Node Environment
NODE_ENV=development

# Admin User Credentials (REQUIRED - İlk admin kullanıcısı için)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password
ADMIN_FULLNAME=Admin User
ADMIN_EMAIL=admin@library.com

# Demo Data (Development için 'true', Production için 'false')
ENABLE_DEMO_DATA=true

# CORS Settings (Production'da güncelleyin)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=your-session-secret-change-this

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
